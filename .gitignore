# Lovable's memory:
mem:/preferences/*


# Global Security Failsafes
# Prevents any .env file in any subfolder from being committed
.env
.env.*
!.env.example

# Global Python Failsafes
# Prevents virtual environments and cache files from bloating the monorepo
.venv/
__pycache__/
*.pyc

